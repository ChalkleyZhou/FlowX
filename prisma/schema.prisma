generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Requirement {
  id                 String   @id @default(cuid())
  status             String   @default("ACTIVE")
  title              String
  description        String
  acceptanceCriteria String
  workspaceId        String?
  workspace          Workspace? @relation(fields: [workspaceId], references: [id])
  workflowRuns       WorkflowRun[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Workspace {
  id           String       @id @default(cuid())
  status       String       @default("ACTIVE")
  name         String
  description  String?
  repositories Repository[]
  requirements Requirement[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Repository {
  id            String    @id @default(cuid())
  status        String    @default("ACTIVE")
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  name          String
  url           String
  defaultBranch String?
  currentBranch String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model User {
  id            String          @id @default(cuid())
  account       String?         @unique
  email         String?         @unique
  displayName   String
  avatarUrl     String?
  status        String          @default("ACTIVE")
  localCredential LocalCredential?
  identities    AuthIdentity[]
  sessions      UserSession[]
  memberships   UserOrganization[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model LocalCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  account      String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuthIdentity {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  provider              String
  providerUserId        String
  providerUnionId       String?
  providerRawProfile    Json?
  lastLoginAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([provider, providerUserId])
}

model Organization {
  id                    String             @id @default(cuid())
  provider              String
  providerOrganizationId String
  name                  String
  logoUrl               String?
  memberships           UserOrganization[]
  sessions              UserSession[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([provider, providerOrganizationId])
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model UserSession {
  id            String    @id @default(cuid())
  token         String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model OAuthState {
  id          String   @id @default(cuid())
  provider    String
  state       String   @unique
  redirectUri String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PendingOrganizationSelection {
  id             String   @id @default(cuid())
  token          String   @unique
  provider       String
  profile        Json
  organizations  Json
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WorkflowRun {
  id              String @id @default(cuid())
  status          String @default("CREATED")
  currentStage    String?
  requirementId  String
  requirement    Requirement @relation(fields: [requirementId], references: [id])
  stageExecutions StageExecution[]
  tasks          Task[]
  plan           Plan?
  codeExecution  CodeExecution?
  reviewReport   ReviewReport?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StageExecution {
  id           String @id @default(cuid())
  workflowRunId String
  workflowRun  WorkflowRun @relation(fields: [workflowRunId], references: [id])
  stage        String
  attempt      Int @default(1)
  status       String @default("PENDING")
  input        Json?
  output       Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workflowRunId, stage, attempt])
}

model Task {
  id           String @id @default(cuid())
  workflowRunId String
  workflowRun  WorkflowRun @relation(fields: [workflowRunId], references: [id])
  title        String
  description  String
  order        Int
  status       String @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id                 String @id @default(cuid())
  workflowRunId      String     @unique
  workflowRun        WorkflowRun @relation(fields: [workflowRunId], references: [id])
  status             String @default("DRAFT")
  summary            String
  implementationPlan Json
  filesToModify      Json
  newFiles           Json
  riskPoints         Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CodeExecution {
  id           String @id @default(cuid())
  workflowRunId String             @unique
  workflowRun  WorkflowRun @relation(fields: [workflowRunId], references: [id])
  status       String @default("RUNNING")
  patchSummary String
  changedFiles Json
  codeChanges  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReviewReport {
  id           String @id @default(cuid())
  workflowRunId String             @unique
  workflowRun  WorkflowRun @relation(fields: [workflowRunId], references: [id])
  status       String @default("COMPLETED")
  issues       Json
  bugs         Json
  missingTests Json
  suggestions  Json
  impactScope  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
