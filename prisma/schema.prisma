generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Requirement {
  id                      String                  @id @default(cuid())
  status                  String                  @default("ACTIVE")
  title                   String
  description             String
  acceptanceCriteria      String
  projectId               String
  project                 Project                 @relation(fields: [projectId], references: [id])
  workspaceId             String?
  workspace               Workspace?              @relation(fields: [workspaceId], references: [id])
  ideationStatus          String                  @default("NONE")
  requirementRepositories RequirementRepository[]
  ideationSessions        IdeationSession[]
  ideationArtifacts       IdeationArtifact[]
  workflowRuns            WorkflowRun[]
  issues                  Issue[]
  bugs                    Bug[]                   @relation("BugSourceRequirement")
  fixingBugs              Bug[]                   @relation("BugFixRequirement")
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([projectId, createdAt])
}

model Workspace {
  id           String        @id @default(cuid())
  status       String        @default("ACTIVE")
  name         String
  description  String?
  projects     Project[]
  repositories Repository[]
  requirements Requirement[]
  issues       Issue[]
  bugs         Bug[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Project {
  id           String        @id @default(cuid())
  status       String        @default("ACTIVE")
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  name         String
  code         String?
  description  String?
  requirements Requirement[]
  legacyDeployConfig ProjectDeployConfig?
  deployJobs   DeployJobRecord[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([workspaceId, createdAt])
}

model ProjectDeployConfig {
  id         String   @id @default(cuid())
  projectId  String   @unique
  project    Project  @relation(fields: [projectId], references: [id])
  enabled    Boolean  @default(false)
  provider   String   @default("noop")
  configJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DeployJobRecord {
  id              String   @id @default(cuid())
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  repositoryId    String?
  repository      Repository? @relation(fields: [repositoryId], references: [id])
  workflowRunId   String?
  workflowRun     WorkflowRun? @relation(fields: [workflowRunId], references: [id])
  provider        String
  status          String   @default("PENDING")
  targetEnv       String?
  branch          String?
  commitSha       String?
  version         String?
  versionImage    String?
  image           String?
  requestedBy     String?
  requestPayload  Json?
  responsePayload Json?
  externalJobId   String?
  externalJobUrl  String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, createdAt])
  @@index([repositoryId, createdAt])
  @@index([workflowRunId, createdAt])
  @@index([provider, createdAt])
}

model Repository {
  id                      String                  @id @default(cuid())
  status                  String                  @default("ACTIVE")
  workspaceId             String
  workspace               Workspace               @relation(fields: [workspaceId], references: [id])
  name                    String
  url                     String
  defaultBranch           String?
  currentBranch           String?
  localPath               String?
  syncStatus              String                  @default("PENDING")
  syncError               String?
  lastSyncedAt            DateTime?
  requirementRepositories RequirementRepository[]
  workflowRepositories    WorkflowRepository[]
  deployConfig            RepositoryDeployConfig?
  deployJobs              DeployJobRecord[]
  issues                  Issue[]
  bugs                    Bug[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

model RepositoryDeployConfig {
  id         String     @id @default(cuid())
  repositoryId String   @unique
  repository Repository @relation(fields: [repositoryId], references: [id])
  enabled    Boolean    @default(false)
  provider   String     @default("noop")
  configJson Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model User {
  id              String             @id @default(cuid())
  account         String?            @unique
  email           String?            @unique
  displayName     String
  avatarUrl       String?
  status          String             @default("ACTIVE")
  localCredential LocalCredential?
  aiCredentials   UserAiCredential[]
  identities      AuthIdentity[]
  sessions        UserSession[]
  memberships     UserOrganization[]
  reportedIssues  Issue[]            @relation("IssueReportedBy")
  assignedIssues  Issue[]            @relation("IssueAssignedTo")
  reportedBugs    Bug[]              @relation("BugReportedBy")
  assignedBugs    Bug[]              @relation("BugAssignedTo")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model LocalCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  account      String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserAiCredential {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  provider        String
  encryptedSecret String
  keyVersion      Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider])
}

model OrganizationAiCredential {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  provider        String
  encryptedSecret String
  keyVersion      Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, provider])
}

model AuthIdentity {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  provider           String
  providerUserId     String
  providerUnionId    String?
  providerRawProfile Json?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([provider, providerUserId])
}

model Organization {
  id                     String             @id @default(cuid())
  provider               String
  providerOrganizationId String
  name                   String
  logoUrl                String?
  aiCredentials          OrganizationAiCredential[]
  memberships            UserOrganization[]
  sessions               UserSession[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@unique([provider, providerOrganizationId])
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model UserSession {
  id             String        @id @default(cuid())
  token          String        @unique
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expiresAt      DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OAuthState {
  id          String    @id @default(cuid())
  provider    String
  state       String    @unique
  redirectUri String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PendingOrganizationSelection {
  id            String    @id @default(cuid())
  token         String    @unique
  provider      String
  profile       Json
  organizations Json
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WorkflowRun {
  id                   String               @id @default(cuid())
  status               String               @default("CREATED")
  currentStage         String?
  aiProvider           String               @default("codex")
  requirementId        String
  requirement          Requirement          @relation(fields: [requirementId], references: [id])
  stageExecutions      StageExecution[]
  tasks                Task[]
  plan                 Plan?
  codeExecution        CodeExecution?
  reviewReport         ReviewReport?
  workflowRepositories WorkflowRepository[]
  deployJobs           DeployJobRecord[]
  reviewFindings       ReviewFinding[]
  issues               Issue[]
  bugs                 Bug[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model WorkflowRepository {
  id            String      @id @default(cuid())
  workflowRunId String
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id])
  repositoryId  String?
  repository    Repository? @relation(fields: [repositoryId], references: [id])
  name          String
  url           String
  baseBranch    String
  workingBranch String
  localPath     String?
  contextSnapshot Json?
  contextGeneratedAt DateTime?
  status        String      @default("PENDING")
  syncError     String?
  preparedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([workflowRunId, createdAt])
}

model RequirementRepository {
  id            String      @id @default(cuid())
  requirementId String
  requirement   Requirement @relation(fields: [requirementId], references: [id])
  repositoryId  String
  repository    Repository  @relation(fields: [repositoryId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([requirementId, repositoryId])
  @@index([repositoryId, createdAt])
}

model StageExecution {
  id             String          @id @default(cuid())
  workflowRunId  String
  workflowRun    WorkflowRun     @relation(fields: [workflowRunId], references: [id])
  stage          String
  attempt        Int             @default(1)
  status         String          @default("PENDING")
  statusMessage  String?
  input          Json?
  output         Json?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  reviewFindings ReviewFinding[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workflowRunId, stage, attempt])
}

model Task {
  id            String      @id @default(cuid())
  workflowRunId String
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id])
  title         String
  description   String
  surface       String?
  repositoryNames Json?
  order         Int
  status        String      @default("DRAFT")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Plan {
  id                 String      @id @default(cuid())
  workflowRunId      String      @unique
  workflowRun        WorkflowRun @relation(fields: [workflowRunId], references: [id])
  status             String      @default("DRAFT")
  summary            String
  implementationPlan Json
  filesToModify      Json
  newFiles           Json
  riskPoints         Json
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model CodeExecution {
  id            String      @id @default(cuid())
  workflowRunId String      @unique
  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id])
  status        String      @default("RUNNING")
  patchSummary  String
  changedFiles  Json
  codeChanges   Json
  diffArtifacts Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ReviewReport {
  id             String          @id @default(cuid())
  workflowRunId  String          @unique
  workflowRun    WorkflowRun     @relation(fields: [workflowRunId], references: [id])
  status         String          @default("COMPLETED")
  issues         Json
  bugs           Json
  missingTests   Json
  suggestions    Json
  impactScope    Json
  reviewFindings ReviewFinding[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ReviewFinding {
  id                     String          @id @default(cuid())
  status                 String          @default("OPEN")
  type                   String
  sourceType             String
  sourceIndex            Int
  severity               String          @default("MEDIUM")
  title                  String
  description            String
  recommendation         String?
  impactScope            Json?
  metadata               Json?
  reviewReportId         String
  reviewReport           ReviewReport    @relation(fields: [reviewReportId], references: [id])
  workflowRunId          String
  workflowRun            WorkflowRun     @relation(fields: [workflowRunId], references: [id])
  sourceStageExecutionId String?
  sourceStageExecution   StageExecution? @relation(fields: [sourceStageExecutionId], references: [id])
  convertedIssueId       String?         @unique
  convertedIssue         Issue?          @relation("FindingToIssue", fields: [convertedIssueId], references: [id])
  convertedBugId         String?         @unique
  convertedBug           Bug?            @relation("FindingToBug", fields: [convertedBugId], references: [id])
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@unique([reviewReportId, sourceType, sourceIndex])
  @@index([workflowRunId, type, status])
  @@index([reviewReportId, createdAt])
}

model Issue {
  id               String         @id @default(cuid())
  status           String         @default("OPEN")
  priority         String         @default("MEDIUM")
  title            String
  description      String
  resolution       String?
  workspaceId      String
  workspace        Workspace      @relation(fields: [workspaceId], references: [id])
  requirementId    String?
  requirement      Requirement?   @relation(fields: [requirementId], references: [id])
  workflowRunId    String?
  workflowRun      WorkflowRun?   @relation(fields: [workflowRunId], references: [id])
  reviewFinding    ReviewFinding? @relation("FindingToIssue")
  repositoryId     String?
  repository       Repository?    @relation(fields: [repositoryId], references: [id])
  branchName       String?
  assigneeUserId   String?
  assigneeUser     User?          @relation("IssueAssignedTo", fields: [assigneeUserId], references: [id])
  reportedByUserId String?
  reportedByUser   User?          @relation("IssueReportedBy", fields: [reportedByUserId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([workspaceId, status, priority])
  @@index([workflowRunId, createdAt])
}

model IdeationSession {
  id             String   @id @default(cuid())
  requirementId  String
  requirement    Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  events         IdeationSessionEvent[]
  stage          String
  attempt        Int      @default(1)
  status         String   @default("PENDING")
  statusMessage  String?
  input          Json?
  output         Json?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([requirementId])
}

model IdeationSessionEvent {
  id         String   @id @default(cuid())
  sessionId  String
  session    IdeationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType  String
  stage      String
  message    String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([sessionId, createdAt])
}

model IdeationArtifact {
  id             String   @id @default(cuid())
  requirementId  String
  requirement    Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  type           String
  content        Json
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([requirementId])
}

model Bug {
  id                String         @id @default(cuid())
  status            String         @default("OPEN")
  severity          String         @default("MEDIUM")
  priority          String         @default("MEDIUM")
  title             String
  description       String
  expectedBehavior  String?
  actualBehavior    String?
  reproductionSteps Json?
  resolution        String?
  workspaceId       String
  workspace         Workspace      @relation(fields: [workspaceId], references: [id])
  requirementId     String?
  requirement       Requirement?   @relation("BugSourceRequirement", fields: [requirementId], references: [id])
  workflowRunId     String?
  workflowRun       WorkflowRun?   @relation(fields: [workflowRunId], references: [id])
  reviewFinding     ReviewFinding? @relation("FindingToBug")
  repositoryId      String?
  repository        Repository?    @relation(fields: [repositoryId], references: [id])
  branchName        String?
  fixRequirementId  String?
  fixRequirement    Requirement?   @relation("BugFixRequirement", fields: [fixRequirementId], references: [id])
  assigneeUserId    String?
  assigneeUser      User?          @relation("BugAssignedTo", fields: [assigneeUserId], references: [id])
  reportedByUserId  String?
  reportedByUser    User?          @relation("BugReportedBy", fields: [reportedByUserId], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([workspaceId, status, severity, priority])
  @@index([workflowRunId, createdAt])
}
