{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["design"],
  "properties": {
    "design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview", "pages", "demoScenario", "designRationale"],
      "properties": {
        "overview": {
          "type": "string",
          "minLength": 1
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "route", "layout", "keyComponents", "interactions"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "route": {
                "type": "string",
                "minLength": 1
              },
              "layout": {
                "type": "string",
                "minLength": 1
              },
              "keyComponents": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "interactions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "demoScenario": {
          "type": "string",
          "minLength": 1
        },
        "designRationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
