{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BriefingSummaryOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["headline", "summaryParagraph", "topics", "openQuestions"],
  "properties": {
    "headline": {
      "type": "string",
      "description": "一句话概括 commits 能够明确支持的项目变化。"
    },
    "summaryParagraph": {
      "type": "string",
      "description": "1-2 句自然语言总结，不补充 commits 未表达的结论。"
    },
    "topics": {
      "type": "array",
      "items": { "$ref": "#/$defs/topic" }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "commit 描述中缺失且需要人工确认的信息；无则空数组。"
    }
  },
  "$defs": {
    "topic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "modules", "commitReferences"],
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "modules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commitReferences": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/commitReference" }
        }
      }
    },
    "commitReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commitId"],
      "properties": {
        "repository": { "type": "string" },
        "commitId": { "type": "string" }
      }
    }
  }
}
