{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["brief"],
  "properties": {
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expandedDescription", "userStories", "edgeCases", "successMetrics", "openQuestions", "assumptions", "outOfScope"],
      "properties": {
        "expandedDescription": {
          "type": "string",
          "minLength": 1
        },
        "userStories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "action", "benefit"],
            "properties": {
              "role": {
                "type": "string",
                "minLength": 1
              },
              "action": {
                "type": "string",
                "minLength": 1
              },
              "benefit": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "edgeCases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "successMetrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "openQuestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outOfScope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
