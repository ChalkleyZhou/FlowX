{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DesignPhaseOutput",
  "description": "设计阶段（OpenDesign 高保真）输出：顶层含 design、demo 与 designArtifact（内联单页 HTML）。本阶段不要求 demoPages。",
  "type": "object",
  "additionalProperties": false,
  "required": ["design", "demo", "designArtifact"],
  "properties": {
    "design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview", "pages", "demoScenario", "designRationale"],
      "properties": {
        "overview": {
          "type": "string",
          "minLength": 1,
          "description": "高层设计思路（非 API/库表设计）。"
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "route", "layout", "keyComponents", "interactions"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "route": { "type": "string", "minLength": 1 },
              "layout": { "type": "string", "minLength": 1 },
              "keyComponents": {
                "type": "array",
                "items": { "type": "string" }
              },
              "interactions": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "demoScenario": { "type": "string", "minLength": 1 },
        "designRationale": { "type": "string", "minLength": 1 }
      }
    },
    "demo": {
      "type": "object",
      "description": "Demo 摘要，用于确认与后续任务拆解。",
      "additionalProperties": false,
      "required": ["summary", "flows", "scope", "knownGaps"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "flows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "goal", "entry", "states"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "goal": { "type": "string", "minLength": 1 },
              "entry": { "type": "string", "minLength": 1 },
              "states": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "excluded"],
          "properties": {
            "included": {
              "type": "array",
              "items": { "type": "string" }
            },
            "excluded": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "knownGaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "designArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["html"],
      "description": "OpenDesign 高保真单页 HTML 设计稿：html 为完整自包含 HTML 文档字符串（内联样式，可在 sandbox iframe 直接渲染）。",
      "properties": {
        "html": {
          "type": "string",
          "minLength": 1,
          "description": "完整单页 HTML 文档（<!doctype html> 起始，内联 CSS，无需外部资源）。"
        },
        "relPath": { "type": "string" },
        "generatedAt": { "type": "string" },
        "bytes": { "type": "number" }
      }
    }
  }
}
