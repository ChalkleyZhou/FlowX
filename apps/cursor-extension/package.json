{
  "name": "flowx-cursor-extension",
  "displayName": "FlowX",
  "version": "0.1.0",
  "private": true,
  "publisher": "flowx",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flowx",
          "title": "FlowX",
          "icon": "resources/flowx.svg"
        }
      ]
    },
    "views": {
      "flowx": [
        {
          "id": "flowxTasks",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "flowx.configure",
        "title": "FlowX: Sign in"
      },
      {
        "command": "flowx.signOut",
        "title": "FlowX: Sign out"
      },
      {
        "command": "flowx.refreshTasks",
        "title": "FlowX: Refresh Tasks"
      },
      {
        "command": "flowx.openRequirements",
        "title": "FlowX: Open Requirements"
      },
      {
        "command": "flowx.showTaskActions",
        "title": "FlowX: Task Actions"
      },
      {
        "command": "flowx.startInChat",
        "title": "FlowX: Start in Chat"
      },
      {
        "command": "flowx.reportCompletion",
        "title": "FlowX: Report Completion"
      },
      {
        "command": "flowx.openRunDetail",
        "title": "FlowX: Open Workflow Run"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "flowx.showTaskActions",
          "when": "view == flowxTasks && (viewItem == flowxTask.startable || viewItem == flowxTask.reportable)",
          "group": "inline"
        },
        {
          "command": "flowx.refreshTasks",
          "when": "view == flowxTasks",
          "group": "navigation"
        },
        {
          "command": "flowx.signOut",
          "when": "view == flowxTasks",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
